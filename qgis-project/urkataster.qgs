                    <Option name="Size" type="Map">
                      <Option name="active" type="bool" value="true"/>
                      <Option name="expression" type="QString" value="CASE WHEN @vector_tile_zoom >= 8 AND @vector_tile_zoom &lt;= 10 THEN (scale_linear(@vector_tile_zoom,8,10,CASE WHEN &quot;size&quot; IN (10, 9) THEN 12 WHEN &quot;size&quot; IN (8, 7) THEN 10 ELSE 10 END,CASE WHEN &quot;size&quot; IN (10, 9) THEN 22 WHEN &quot;size&quot; IN (8, 7, 6) THEN 18 WHEN &quot;size&quot; IN (5, 4) THEN 16 WHEN &quot;size&quot; = 3 THEN 14 WHEN &quot;size&quot; = 2 THEN 12 WHEN &quot;size&quot; = 1 THEN 10 ELSE 10 END)) * 0.264583 WHEN @vector_tile_zoom > 10 AND @vector_tile_zoom &lt;= 12 THEN (scale_linear(@vector_tile_zoom,10,12,CASE WHEN &quot;size&quot; IN (10, 9) THEN 22 WHEN &quot;size&quot; IN (8, 7, 6) THEN 18 WHEN &quot;size&quot; IN (5, 4) THEN 16 WHEN &quot;size&quot; = 3 THEN 14 WHEN &quot;size&quot; = 2 THEN 12 WHEN &quot;size&quot; = 1 THEN 10 ELSE 10 END,CASE WHEN &quot;size&quot; IN (10, 9) THEN 24 WHEN &quot;size&quot; IN (8, 7) THEN 22 WHEN &quot;size&quot; IN (6, 5, 4, 3) THEN 20 WHEN &quot;size&quot; = 2 THEN 16 WHEN &quot;size&quot; = 1 THEN 12 ELSE 12 END)) * 0.264583 WHEN @vector_tile_zoom > 12 AND @vector_tile_zoom &lt;= 14 THEN (scale_linear(@vector_tile_zoom,12,14,CASE WHEN &quot;size&quot; IN (10, 9) THEN 24 WHEN &quot;size&quot; IN (8, 7) THEN 22 WHEN &quot;size&quot; IN (6, 5, 4, 3) THEN 20 WHEN &quot;size&quot; = 2 THEN 16 WHEN &quot;size&quot; = 1 THEN 12 ELSE 12 END,CASE WHEN &quot;size&quot; IN (10, 9) THEN 28 WHEN &quot;size&quot; IN (8, 7) THEN 26 WHEN &quot;size&quot; IN (6, 5, 4, 3) THEN 24 WHEN &quot;size&quot; = 2 THEN 22 WHEN &quot;size&quot; = 1 THEN 14 ELSE 12 END)) * 0.264583 WHEN @vector_tile_zoom > 14 AND @vector_tile_zoom &lt;= 15 THEN (scale_linear(@vector_tile_zoom,14,15,CASE WHEN &quot;size&quot; IN (10, 9) THEN 28 WHEN &quot;size&quot; IN (8, 7) THEN 26 WHEN &quot;size&quot; IN (6, 5, 4, 3) THEN 24 WHEN &quot;size&quot; = 2 THEN 22 WHEN &quot;size&quot; = 1 THEN 14 ELSE 12 END,CASE WHEN &quot;size&quot; IN (10, 9) THEN 30 WHEN &quot;size&quot; IN (8, 7) THEN 28 WHEN &quot;size&quot; IN (6, 5, 4, 3) THEN 26 WHEN &quot;size&quot; = 2 THEN 24 WHEN &quot;size&quot; = 1 THEN 18 ELSE 18 END)) * 0.264583 WHEN @vector_tile_zoom > 15 THEN ( ( CASE WHEN &quot;size&quot; IN (10, 9) THEN 30 WHEN &quot;size&quot; IN (8, 7) THEN 28 WHEN &quot;size&quot; IN (6, 5, 4, 3) THEN 26 WHEN &quot;size&quot; = 2 THEN 24 WHEN &quot;size&quot; = 1 THEN 18 ELSE 18 END ) * 0.264583 ) END"/>
                      <Option name="type" type="int" value="3"/>
                    </Option>
