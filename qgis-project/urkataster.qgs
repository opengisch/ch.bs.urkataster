                          <Option name="expression" type="QString" value="CASE WHEN @vector_tile_zoom &lt; 11 THEN set_color_part(@symbol_color, 'alpha', 0) WHEN @vector_tile_zoom >= 11 AND @vector_tile_zoom &lt; 12 THEN set_color_part(@symbol_color, 'alpha', scale_linear(@vector_tile_zoom,11,12,0,51)) WHEN @vector_tile_zoom >= 12 AND @vector_tile_zoom &lt; 14 THEN set_color_part(@symbol_color, 'alpha', scale_linear(@vector_tile_zoom,12,14,51,63.75)) WHEN @vector_tile_zoom >= 14 THEN set_color_part(@symbol_color, 'alpha', 63.75) END"/>
