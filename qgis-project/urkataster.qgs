          <style layer="transportation" name="aerialway" expression="(&quot;class&quot; IN ('cable_car', 'gondola', 'chair_lift'))" max-zoom="-1" min-zoom="12" geometry="1" enabled="1">
            <symbols>
              <symbol name="0" alpha="1" clip_to_extent="1" type="line" force_rhr="0" frame_rate="10" is_animated="0">
