uot; IN ('tertiary', 'rail') THEN 5.5 WHEN &quot;class&quot; = 'minor' THEN 3.5 ELSE 2.5 END,2)) * 0.264583 WHEN @vector_tile_zoom > 15 AND @vector_tile_zoom &lt;= 16 THEN (scale_exponential(@vector_tile_zoom,15,16,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 5 ELSE 6.5 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 6.5 ELSE 7.5 END WHEN &quot;class&quot; = 'primary' THEN 7.5 WHEN &quot;class&quot; = 'secondary' THEN 6.5 WHEN &quot;class&quot; IN ('tertiary', 'rail') THEN 5.5 WHEN &quot;class&quot; = 'minor' THEN 3.5 ELSE 2.5 END,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 8.5 ELSE 10.5 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 10.5 ELSE 13.5 END WHEN &quot;class&quot; = 'primary' THEN 13.5 WHEN &quot;class&quot; = 'secondary' THEN 11.5 WHEN &quot;class&quot; IN ('tertiary', 'rail') THEN 9.5 WHEN &quot;class&quot; = 'minor' THEN 7.5 ELSE 6.5 END,2)) * 0.264583 WHEN @vector_tile_zoom > 16 AND @vector_tile_zoom &lt;= 20 THEN (scale_exponential(@vector_tile_zoom,16,20,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 8.5 ELSE 10.5 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 10.5 ELSE 13.5 END WHEN &quot;class&quot; = 'primary' THEN 13.5 WHEN &quot;class&quot; = 'secondary' THEN 11.5 WHEN &quot;class&quot; IN ('tertiary', 'rail') THEN 9.5 WHEN &quot;class&quot; = 'minor' THEN 7.5 ELSE 6.5 END,CASE WHEN &quot;class&quot; IN ('motorway', 'trunk', 'primary', 'rail') THEN 117 WHEN &quot;class&quot; = 'secondary' THEN 112 WHEN &quot;class&quot; = 'tertiary' THEN 107 WHEN &quot;class&quot; = 'minor' THEN 97 ELSE 92 END,2)) * 0.264583 WHEN @vector_tile_zoom > 20 THEN ( ( CASE WHEN &quot;class&quot; IN ('motorway', 'trunk', 'primary', 'rail') THEN 117 WHEN &quot;class&quot; = 'secondary' THEN 112 WHEN &quot;class&quot; = 'tertiary' THEN 107 WHEN &quot;clas