                          <Option name="expression" type="QString" value="CASE WHEN @vector_tile_zoom >= 7 AND @vector_tile_zoom &lt;= 10 THEN (scale_exponential(@vector_tile_zoom,7,10,1,CASE WHEN &quot;&quot; IN ('10', '9', '8', '7', '6') THEN 1.5 WHEN &quot;&quot; IN ('5', '4', '3', '2', '1') THEN 1 ELSE CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN 1.5 ELSE 1 END END,1.5)) * 0.264583 WHEN @vector_tile_zoom > 10 AND @vector_tile_zoom &lt;= 13 THEN (scale_exponential(@vector_tile_zoom,10,13,CASE WHEN &quot;&quot; IN ('10', '9', '8', '7', '6') THEN 1.5 WHEN &quot;&quot; IN ('5', '4', '3', '2', '1') THEN 1 ELSE CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN 1.5 ELSE 1 END END,CASE WHEN &quot;&quot; IN ('10', '9', '8') THEN 3.5 WHEN &quot;&quot; IN ('7', '6', '5') THEN 2.5 WHEN &quot;&quot; IN ('4', '3') THEN 1.5 WHEN &quot;&quot; IN ('1', '2') THEN 1 ELSE CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN 3.5 ELSE 1 END END,1.5)) * 0.264583 WHEN @vector_tile_zoom > 13 AND @vector_tile_zoom &lt;= 16 THEN (scale_exponential(@vector_tile_zoom,13,16,CASE WHEN &quot;&quot; IN ('10', '9', '8') THEN 3.5 WHEN &quot;&quot; IN ('7', '6', '5') THEN 2.5 WHEN &quot;&quot; IN ('4', '3') THEN 1.5 WHEN &quot;&quot; IN ('1', '2') THEN 1 ELSE CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN 3.5 ELSE 1 END END,CASE WHEN (&quot;&quot; = '10') THEN 5 WHEN (&quot;&quot; = '9') THEN 4.5 WHEN (&quot;&quot; = '8') THEN 4 WHEN (&quot;&quot; = '7') THEN 3.5 WHEN &quot;&quot; IN ('6', '5') THEN 3 WHEN (&quot;&quot; = '4') THEN 2.5 WHEN (&quot;&quot; = '3') THEN 2 WHEN (&quot;&quot; = '2') THEN 1.5 WHEN (&quot;&quot; = '1') THEN 1 ELSE CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN 5 ELSE 1.5 END END,1.5)) * 0.264583 WHEN @vector_tile_zoom > 16 AND @vector_tile_zoom &lt;= 20 THEN (scale_exponential(@vector_tile_zoom,16,20,CASE WHEN (&quot;&quot; = '10') THEN 5 WHEN (&quot;&quot; = '9') THEN 4.5 WHEN (&quot;&quot; = '8') THEN 4 WHEN (&quot;&quot; = '7') THEN 3.5 WHEN &quot;&quot; IN ('6', '5') THEN 3 WHEN (&quot;&quot; = '4') THEN 2.5 WHEN (&quot;&quot; = '3') THEN 2 WHEN (&quot;&quot; = '2') THEN 1.5 WHEN (&quot;&quot; = '1') THEN 1 ELSE CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN 5 ELSE 1.5 END END,CASE WHEN (&quot;&quot; = '10') THEN 10 WHEN (&quot;&quot; = '9') THEN 9.6 WHEN (&quot;&quot; = '8') THEN 8.9 WHEN (&quot;&quot; = '7') THEN 8.2 WHEN (&quot;&quot; = '6') THEN 7.5 WHEN (&quot;&quot; = '5') THEN 6.8 WHEN (&quot;&quot; = '4') THEN 6.1 WHEN (&quot;&quot; = '3') THEN 5.4 WHEN (&quot;&quot; = '2') THEN 4.7 WHEN (&quot;&quot; = '1') THEN 4 ELSE CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN 10 ELSE 4 END END,1.5)) * 0.264583 WHEN @vector_tile_zoom > 20 THEN ( ( CASE WHEN (&quot;&quot; = '10') THEN 10 WHEN (&quot;&quot; = '9') THEN 9.6 WHEN (&quot;&quot; = '8') THEN 8.9 WHEN (&quot;&quot; = '7') THEN 8.2 WHEN (&quot;&quot; = '6') THEN 7.5 WHEN (&quot;&quot; = '5') THEN 6.8 WHEN (&quot;&quot; = '4') THEN 6.1 WHEN (&quot;&quot; = '3') THEN 5.4 WHEN (&quot;&quot; = '2') THEN 4.7 WHEN (&quot;&quot; = '1') THEN 4 ELSE CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN 10 ELSE 4 END END ) * 0.264583 ) END"/>
