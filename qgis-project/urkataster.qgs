                          <Option name="expression" type="QString" value="CASE WHEN @vector_tile_zoom >= 9 AND @vector_tile_zoom &lt; 15 THEN color_hsla(scale_exponential(@vector_tile_zoom,9,15,color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(170,136,30,255) ELSE color_rgba(80,80,80,255) END,'hsl_hue'),color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(139,107,63,255) ELSE color_rgba(90,90,90,255) END,'hsl_hue'),1.7), scale_exponential(@vector_tile_zoom,9,15,color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(170,136,30,255) ELSE color_rgba(80,80,80,255) END,'hsl_saturation'),color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(139,107,63,255) ELSE color_rgba(90,90,90,255) END,'hsl_saturation'),1.7), scale_exponential(@vector_tile_zoom,9,15,color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(170,136,30,255) ELSE color_rgba(80,80,80,255) END,'lightness'),color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(139,107,63,255) ELSE color_rgba(90,90,90,255) END,'lightness'),1.7), scale_exponential(@vector_tile_zoom,9,15,color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(170,136,30,255) ELSE color_rgba(80,80,80,255) END,'alpha'),color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(139,107,63,255) ELSE color_rgba(90,90,90,255) END,'alpha'),1.7)) WHEN @vector_tile_zoom >= 15 THEN color_hsla(color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(139,107,63,255) ELSE color_rgba(90,90,90,255) END,'hsl_hue'), color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(139,107,63,255) ELSE color_rgba(90,90,90,255) END,'hsl_saturation'), color_part(CASE WHEN &quot;class&quot; IN ('motorway', 'trunk') THEN color_rgba(139,107,63,255) ELSE color_rgba(90,90,90,255) END,'lightness'), color_part(CASE WHEN &quot;class&quot