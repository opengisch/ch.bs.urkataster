                        <Option name="enabled" type="Map">
                          <Option name="active" type="bool" value="true"/>
                          <Option name="expression" type="QString" value="(CASE WHEN @vector_tile_zoom >= 7 AND @vector_tile_zoom &lt;= 8 THEN (scale_exponential(@vector_tile_zoom,7,8,0,CASE WHEN (&quot;ramp&quot; = 1) THEN 1.5 ELSE 3 END,2)) * 0.264583 WHEN @vector_tile_zoom > 8 AND @vector_tile_zoom &lt;= 10 THEN (scale_exponential(@vector_tile_zoom,8,10,CASE WHEN (&quot;ramp&quot; = 1) THEN 1.5 ELSE 3 END,CASE WHEN (&quot;is_route&quot; = 11) THEN 0 ELSE CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 2.5 ELSE 4 END WHEN &quot;class&quot; = 'trunk' THEN 4 ELSE 3 END END,2)) * 0.264583 WHEN @vector_tile_zoom > 10 AND @vector_tile_zoom &lt;= 11 THEN (scale_exponential(@vector_tile_zoom,10,11,CASE WHEN (&quot;is_route&quot; = 11) THEN 0 ELSE CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 2.5 ELSE 4 END WHEN &quot;class&quot; = 'trunk' THEN 4 ELSE 3 END END,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 2.5 ELSE 4 END WHEN &quot;class&quot; = 'trunk' THEN 4 ELSE CASE WHEN (&quot;is_route&quot; = 11) THEN 0 ELSE 3 END END,2)) * 0.264583 WHEN @vector_tile_zoom > 11 AND @vector_tile_zoom &lt;= 12 THEN (scale_exponential(@vector_tile_zoom,11,12,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 2.5 ELSE 4 END WHEN &quot;class&quot; = 'trunk' THEN 4 ELSE CASE WHEN (&quot;is_route&quot; = 11) THEN 0 ELSE 3 END END,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 3 ELSE 5 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 5 ELSE 5 END WHEN &quot;class&quot; = 'primary' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 5 ELSE 0 END WHEN &quot;class&quot; = 'secondary' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 4.5 ELSE 0 END WHEN &quot;class&quot; = 'tertiary' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 3.25 ELSE 0 END WHEN &quot;class&quot; = 'track' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 0.75 ELSE 0 END WHEN &quot;class&quot; = 'minor' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 3 ELSE 0 END ELSE 0 END,2)) * 0.264583 WHEN @vector_tile_zoom > 12 AND @vector_tile_zoom &lt;= 13 THEN (scale_exponential(@vector_tile_zoom,12,13,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 3 ELSE 5 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 5 ELSE 5 END WHEN &quot;class&quot; = 'primary' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 5 ELSE 0 END WHEN &quot;class&quot; = 'secondary' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 4.5 ELSE 0 END WHEN &quot;class&quot; = 'tertiary' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 3.25 ELSE 0 END WHEN &quot;class&quot; = 'track' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 0.75 ELSE 0 END WHEN &quot;class&quot; = 'minor' THEN CASE WHEN &quot;is_route&quot; = 11 THEN 0.75 WHEN &quot;is_route&quot; IN (5, 6, 7, 8, 9, 10, 99) THEN 3 ELSE 0 END ELSE 0 END,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 3.5 ELSE 5.5 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 5.5 ELSE 5.5 END WHEN &quot;class&quot; = 'primary' THEN 5.5 WHEN &quot;class&quot; = 'secondary' THEN 5 WHEN &quot;class&quot; = 'tertiary' THEN 4 WHEN &quot;class&quot; = 'minor' THEN 3 ELSE 0 END,2)) * 0.264583 WHEN @vector_tile_zoom > 13 AND @vector_tile_zoom &lt;= 15 THEN (scale_exponential(@vector_tile_zoom,13,15,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 3.5 ELSE 5.5 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 5.5 ELSE 5.5 END WHEN &quot;class&quot; = 'primary' THEN 5.5 WHEN &quot;class&quot; = 'secondary' THEN 5 WHEN &quot;class&quot; = 'tertiary' THEN 4 WHEN &quot;class&quot; = 'minor' THEN 3 ELSE 0 END,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 6.5 ELSE 8 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 8 ELSE 9 END WHEN &quot;class&quot; = 'primary' THEN 9 WHEN &quot;class&quot; = 'secondary' THEN 8 WHEN &quot;class&quot; = 'tertiary' THEN 7 WHEN &quot;class&quot; = 'minor' THEN 5 WHEN &quot;class&quot; = 'track' THEN 1.1 ELSE 4 END,2)) * 0.264583 WHEN @vector_tile_zoom > 15 AND @vector_tile_zoom &lt;= 16 THEN (scale_exponential(@vector_tile_zoom,15,16,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 6.5 ELSE 8 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 8 ELSE 9 END WHEN &quot;class&quot; = 'primary' THEN 9 WHEN &quot;class&quot; = 'secondary' THEN 8 WHEN &quot;class&quot; = 'tertiary' THEN 7 WHEN &quot;class&quot; = 'minor' THEN 5 WHEN &quot;class&quot; = 'track' THEN 1.1 ELSE 4 END,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quot;ramp&quot; = 1) THEN 10 ELSE 12 END WHEN &quot;class&quot; = 'trunk' THEN CASE WHEN (&quot;oneway&quot; = 1) THEN 12 ELSE 15 END WHEN &quot;class&quot; = 'primary' THEN 15 WHEN &quot;class&quot; = 'secondary' THEN 13 WHEN &quot;class&quot; = 'tertiary' THEN 11 WHEN &quot;class&quot; = 'minor' THEN 9 WHEN &quot;class&quot; = 'track' THEN 1.1 ELSE 8 END,2)) * 0.264583 WHEN @vector_tile_zoom > 16 AND @vector_tile_zoom &lt;= 20 THEN (scale_exponential(@vector_tile_zoom,16,20,CASE WHEN &quot;class&quot; = 'motorway' THEN CASE WHEN (&quo