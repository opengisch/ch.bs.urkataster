                        <Option name="expression" type="QString" value="CASE WHEN @vector_tile_zoom >= 12 AND @vector_tile_zoom &lt;= 13 THEN (scale_linear(@vector_tile_zoom,12,13,0,CASE WHEN &quot;class&quot; IN ('cable_car', 'gondola') THEN 1 ELSE 0 END)) * 100 WHEN @vector_tile_zoom > 13 AND @vector_tile_zoom &lt;= 14 THEN (scale_linear(@vector_tile_zoom,13,14,CASE WHEN &quot;class&quot; IN ('cable_car', 'gondola') THEN 1 ELSE 0 END,CASE WHEN &quot;class&quot; IN ('cable_car', 'gondola', 'chair_lift') THEN 1 ELSE 0 END)) * 100 WHEN @vector_tile_zoom > 14 THEN ( ( CASE WHEN &quot;class&quot; IN ('cable_car', 'gondola', 'chair_lift') THEN 1 ELSE 0 END ) * 100 ) END"/>
                        <Option name="type" type="int" value="3"/>
                      </Option>
                    </Option>
                    <Option name="type" type="QString" value="collection"/>
