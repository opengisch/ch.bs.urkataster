                      <Option name="expression" type="QString" value="scale_linear(@vector_tile_zoom,7,16,CASE WHEN &quot;size&quot; IN (10, 9, 8) THEN 0.1 WHEN &quot;size&quot; IN (7, 6) THEN 0.04 WHEN &quot;size&quot; IN (5, 4, 3) THEN 0.02 WHEN &quot;size&quot; = 2 THEN 0.01 ELSE 0.05 END,CASE WHEN &quot;size&quot; IN (10, 9, 8) THEN 0.7 WHEN &quot;size&quot; IN (7, 6) THEN 0.5 WHEN &quot;size&quot; IN (5, 4, 3) THEN 0.3 WHEN &quot;size&quot; = 2 THEN 0.2 ELSE 0.1 END)"/>
                      <Option name="type" type="int" value="3"/>
                    </Option>
                    <Option name="LabelRotation" type="Map">
