                          <Option name="expression" type="QString" value="CASE WHEN @vector_tile_zoom &lt; 10 THEN color_hsla(202, 63, 72, 255) WHEN @vector_tile_zoom >= 10 AND @vector_tile_zoom &lt; 16 THEN color_hsla(scale_linear(@vector_tile_zoom,10,16,color_part(color_rgba(138,195,229,255),'hsl_hue'),color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'hsl_hue')), scale_linear(@vector_tile_zoom,10,16,color_part(color_rgba(138,195,229,255),'hsl_saturation'),color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'hsl_saturation')), scale_linear(@vector_tile_zoom,10,16,color_part(color_rgba(138,195,229,255),'lightness'),color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'lightness')), scale_linear(@vector_tile_zoom,10,16,color_part(color_rgba(138,195,229,255),'alpha'),color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'alpha'))) WHEN @vector_tile_zoom >= 16 THEN color_hsla(color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'hsl_hue'), color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'hsl_saturation'), color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'lightness'), color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'alpha')) ELSE color_hsla(color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal') THEN color_rgba(160,205,236,255) ELSE color_rgba(140,185,226,255) END,'hsl_hue'), color_part(CASE WHEN &quot;class&quot; IN ('river', 'canal')