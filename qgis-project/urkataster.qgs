                          <Option name="active" type="bool" value="true"/>
                          <Option name="expression" type="QString" value="array_to_string(array_foreach(CASE WHEN @vector_tile_zoom &lt;= 13 THEN array(3,1) WHEN @vector_tile_zoom > 13 AND @vector_tile_zoom &lt;= 14 THEN array(6,2) WHEN @vector_tile_zoom > 14 AND @vector_tile_zoom &lt;= 15 THEN array(9,3) WHEN @vector_tile_zoom > 15 AND @vector_tile_zoom &lt;= 16 THEN array(12,4) WHEN @vector_tile_zoom > 16 THEN array(15,5) END,@element * (CASE WHEN @vector_tile_zoom >= 8 AND @vector_tile_zoom &lt;= 14 THEN (scale_linear(@vector_tile_zoom,8,14,0.4,1)) * 0.264583 WHEN @vector_tile_zoom > 14 AND @vector_tile_zoom &lt;= 18 THEN (scale_linear(@vector_tile_zoom,14,18,1,2)) * 0.264583 WHEN @vector_tile_zoom > 18 THEN 0.529167 END)), ';')"/>
                          <Option name="type" type="int" value="3"/>
                        </Option>
                        <Option name="enabled" type="Map">
                          <Option name="active" type="bool" value="true"/>
                          <Option name="expression" type="QString" value="(CASE WHEN @vector_tile_zoom >= 8 AND @vector_tile_zoom &lt;= 14 THEN (scale_linear(@vector_tile_zoom,8,14,0.4,1)) * 0.264583 WHEN @vector_tile_zoom > 14 AND @vector_tile_zoom &lt;= 18 THEN (scale_linear(@vector_tile_zoom,14,18,1,2)) * 0.264583 WHEN @vector_tile_zoom > 18 THEN 0.529167 END) > 0"/>
                          <Option name="type" type="int" value="3"/>
                        </Option>
                        <Option name="outlineColor" type="Map">
                          <Option name="active" type="bool" value="true"/>
                          <Option name="expression" type="QString" value="set_color_part(@symbol_color, 'alpha', scale_linear(@vector_tile_zoom,12,13,0,255))"/>
                          <Option name="type" type="int" value="3"/>
                        </Option>
                        <Option name="outlineWidth" type="Map">
                          <Option name="active" type="bool" value="true"/>
                          <Option name="expression" type="QString" value="CASE WHEN @vector_tile_zoom >= 8 AND @vector_tile_zoom &lt;= 14 THEN (scale_linear(@vector_tile_zoom,8,14,0.4,1)) * 0.264583 WHEN @vector_tile_zoom > 14 AND @vector_tile_zoom &lt;= 18 THEN (scale_linear(@vector_tile_zoom,14,18,1,2)) * 0.264583 WHEN @vector_tile_zoom > 18 THEN 0.529167 END"/>
                          <Option name="type" type="int" value="3"/>
                        </Option>
                      </Option>
                      <Option name="type" type="QString" value="collection"/>
                    </Option>
                  </data_defined_properties>
